## provider/src/server.ts
```ts
import express, { Request, Response } from "express";
import bodyParser from "body-parser";
import { Provider, KoaContextWithOIDC } from "oidc-provider";
import bcrypt from "bcrypt";
import Database from "better-sqlite3";

const issuer = "http://provider:5000";

// --- DB ---
const db = new Database("./users.db");
db.prepare(`
  CREATE TABLE IF NOT EXISTS users (
    email TEXT PRIMARY KEY,
    password_hash TEXT NOT NULL,
    name TEXT NOT NULL,
    company_id TEXT NOT NULL
  )
`).run();

const count = (db.prepare("SELECT COUNT(*) as c FROM users").get() as { c: number }).c;
if (count === 0) {
  const insert = db.prepare("INSERT INTO users (email, password_hash, name, company_id) VALUES (?, ?, ?, ?)");
  insert.run("alice@example.com", bcrypt.hashSync("password123", 10), "Alice Example", "COMP-001");
  insert.run("bob@example.com", bcrypt.hashSync("password456", 10), "Bob Example", "COMP-002");
  console.log("Seeded example users into SQLite");
}

// --- OIDC ---
const clients = [
  {
    client_id: "local-client",
    client_secret: "local-secret",
    redirect_uris: ["http://backend:4000/auth/callback"],
    response_types: ["code"],
    grant_types: ["authorization_code"],
  },
];

type Account = {
  accountId: string;
  claims: () => Promise<Record<string, any>>;
};

const configuration = {
  clients,
  features: { devInteractions: { enabled: false } },
  async findAccount(_ctx: KoaContextWithOIDC, id: string): Promise<Account | undefined> {
    const user = db.prepare("SELECT * FROM users WHERE email = ?").get(id) as any;
    if (!user) return undefined;
    return {
      accountId: user.email,
      async claims() {
        return { sub: user.email, name: user.name, email: user.email, company_id: user.company_id };
      },
    };
  },
};

const provider = new Provider(issuer, configuration as any);
const app = express();
app.use(bodyParser.urlencoded({ extended: true }));

// Interacción: login
app.get("/interaction/:uid", async (req: Request, res: Response) => {
  const { uid, prompt } = await provider.interactionDetails(req, res);
  if (prompt.name !== "login") {
    await provider.interactionFinished(req, res, { login: { accountId: "anonymous" } }, { mergeWithLastSubmission: false });
    return;
  }
  res.send(`
    <html>
      <body style="font-family:sans-serif; margin:40px; max-width:420px;">
        <h2>OpenID Login Local</h2>
        <form method="post" action="/interaction/${uid}/login">
          <label>Email</label><br/>
          <input type="email" name="email" required style="width:100%;padding:8px;margin:6px 0"/><br/>
          <label>Password</label><br/>
          <input type="password" name="password" required style="width:100%;padding:8px;margin:6px 0"/><br/>
          <button type="submit" style="padding:8px 14px;">Login</button>
        </form>
      </body>
    </html>
  `);
});

app.post("/interaction/:uid/login", async (req: Request, res: Response) => {
  const { uid } = req.params;
  const { email, password } = req.body as { email?: string; password?: string };
  if (!email || !password) return res.status(400).send("email/password requeridos");

  const user = db.prepare("SELECT * FROM users WHERE email = ?").get(email) as any;
  const ok = user && (await bcrypt.compare(password, user.password_hash));
  if (!ok) return res.status(401).send("<p>Invalid credentials. <a href='javascript:history.back()'>Try again</a></p>");

  const result = { login: { accountId: user.email } };
  await provider.interactionFinished(req, res, result, { mergeWithLastSubmission: false });
});

// Admin (DEV)
app.get("/_admin/users", (_req: Request, res: Response) => {
  const users = db.prepare("SELECT email, name, company_id FROM users").all();
  res.json(users);
});
app.post("/_admin/users/create", bodyParser.json(), async (req: Request, res: Response) => {
  const { email, password, name, company_id } = req.body || {};
  if (!email || !password || !name || !company_id) return res.status(400).json({ error: "missing_fields" });
  const exists = db.prepare("SELECT 1 FROM users WHERE email = ?").get(email);
  if (exists) return res.status(409).json({ error: "user_exists" });
  const password_hash = await bcrypt.hash(password, 10);
  db.prepare("INSERT INTO users (email, password_hash, name, company_id) VALUES (?, ?, ?, ?)").run(email, password_hash, name, company_id);
  res.status(201).json({ ok: true });
});

// Montar provider
app.use(provider.callback());

app.listen(5000, () => console.log("✅ OIDC Provider (SQLite) en http://provider:5000"));
```
