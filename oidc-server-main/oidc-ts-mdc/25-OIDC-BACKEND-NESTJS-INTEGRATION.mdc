## Paso 11: Proteger Módulos Existentes

Ahora que tienes `AuthModule` configurado, puedes proteger cualquier módulo existente.

### Opción A: Proteger un Controller Completo

En tu controller, agrega el decorador `@UseGuards(OIDCAuthGuard)` a nivel de clase:

```typescript
import { Controller, Get, UseGuards } from "@nestjs/common";
import { OIDCAuthGuard } from "../common/guards/oidc-auth.guard";

@Controller("projects")
@UseGuards(OIDCAuthGuard) // Protege TODOS los endpoints de este controller
export class ProjectsController {
  @Get()
  async findAll(@Req() req: Request) {
    // req.user está disponible aquí
    const user = req.user;
    console.log(`User: ${user.email}, Company: ${user.company_id}`);

    // Tu lógica aquí
    return { projects: [] };
  }
}
```

### Opción B: Proteger Endpoints Específicos

```typescript
import { Controller, Get, Post, UseGuards } from "@nestjs/common";
import { OIDCAuthGuard } from "../common/guards/oidc-auth.guard";

@Controller("projects")
export class ProjectsController {
  @Get()
  // Este endpoint NO está protegido
  async findAllPublic() {
    return { projects: [] };
  }

  @Post()
  @UseGuards(OIDCAuthGuard) // Solo este endpoint está protegido
  async create(@Req() req: Request) {
    const user = req.user; // Usuario autenticado disponible
    // Tu lógica aquí
    return { success: true };
  }
}
```

### Opción C: Proteger con Acceso a Usuario

Para acceder a `request.user`, importa `Request` de `express` y úsalo en tu método:

```typescript
import { Controller, Get, Req, UseGuards } from "@nestjs/common";
import { Request } from "express";
import {
  OIDCAuthGuard,
  AuthenticatedUser,
} from "../common/guards/oidc-auth.guard";

@Controller("projects")
@UseGuards(OIDCAuthGuard)
export class ProjectsController {
  @Get()
  async findAll(@Req() req: Request & { user: AuthenticatedUser }) {
    // req.user contiene:
    // - req.user.sub: ID del usuario
    // - req.user.email: Email del usuario
    // - req.user.name: Nombre del usuario
    // - req.user.company_id: ID de la empresa

    const userEmail = req.user.email;
    const companyId = req.user.company_id;

    // Filtrar proyectos por empresa, por ejemplo
    return {
      user: userEmail,
      company: companyId,
      projects: [],
    };
  }
}
```

### Importar AuthModule en tu Módulo

En el módulo donde está tu controller, importa `AuthModule`:

```typescript
import { Module } from "@nestjs/common";
import { TypeOrmModule } from "@nestjs/typeorm";
import { ProjectsController } from "./controllers/projects.controller";
import { ProjectsService } from "./services/projects.service";
import { AuthModule } from "../../auth/auth.module"; // Importar AuthModule

@Module({
  imports: [
    TypeOrmModule.forFeature([Project]),
    AuthModule, // Agregar aquí
  ],
  controllers: [ProjectsController],
  providers: [ProjectsService],
})
export class ProjectsModule {}
```

**CRÍTICO**: Sin importar `AuthModule`, el `OIDCAuthGuard` no tendrá acceso a `JwtService` y `ConfigService`, causando errores de dependencia.

# CodeExamples

## Ejemplo Completo: Proteger un Módulo Existente

Supongamos que tienes un módulo `DocumentsModule` que quieres proteger.

### 1. Importar AuthModule

`src/modules/documents/documents.module.ts`:

```typescript
import { Module } from "@nestjs/common";
import { TypeOrmModule } from "@nestjs/typeorm";
import { Document } from "./entities/document.entity";
import { DocumentsController } from "./controllers/documents.controller";
import { DocumentsService } from "./services/documents.service";
import { AuthModule } from "../../auth/auth.module"; // AGREGAR

@Module({
  imports: [
    TypeOrmModule.forFeature([Document]),
    AuthModule, // AGREGAR
  ],
  controllers: [DocumentsController],
  providers: [DocumentsService],
  exports: [DocumentsService],
})
export class DocumentsModule {}
```

### 2. Proteger el Controller

`src/modules/documents/controllers/documents.controller.ts`:

```typescript
import {
  Controller,
  Get,
  Post,
  Put,
  Delete,
  Param,
  Body,
  Req,
  UseGuards,
} from "@nestjs/common";
import { Request } from "express";
import {
  OIDCAuthGuard,
  AuthenticatedUser,
} from "../../../common/guards/oidc-auth.guard";
import { DocumentsService } from "../services/documents.service";

@Controller("documents")
@UseGuards(OIDCAuthGuard) // Protege TODOS los endpoints
export class DocumentsController {
  constructor(private readonly documentsService: DocumentsService) {}

  @Get()
  async findAll(@Req() req: Request & { user: AuthenticatedUser }) {
    // req.user está disponible
    const companyId = req.user.company_id;

    // Filtrar documentos por empresa
    return this.documentsService.findAllByCompany(companyId);
  }

  @Post()
  async create(
    @Body() createDocumentDto: CreateDocumentDto,
    @Req() req: Request & { user: AuthenticatedUser }
  ) {
    // Usar información del usuario autenticado
    return this.documentsService.create({
      ...createDocumentDto,
      company_id: req.user.company_id,
      created_by: req.user.sub,
    });
  }

  @Get(":id")
  async findOne(
    @Param("id") id: string,
    @Req() req: Request & { user: AuthenticatedUser }
  ) {
    // Verificar que el documento pertenece a la empresa del usuario
    return this.documentsService.findOne(id, req.user.company_id);
  }

  @Put(":id")
  async update(
    @Param("id") id: string,
    @Body() updateDocumentDto: UpdateDocumentDto,
    @Req() req: Request & { user: AuthenticatedUser }
  ) {
    // Verificar permisos y actualizar
    return this.documentsService.update(id, updateDocumentDto, req.user);
  }

  @Delete(":id")
  async remove(
    @Param("id") id: string,
    @Req() req: Request & { user: AuthenticatedUser }
  ) {
    return this.documentsService.remove(id, req.user.company_id);
  }
}
```

### 3. Usar Información del Usuario en el Service

`src/modules/documents/services/documents.service.ts`:

```typescript
import { Injectable } from "@nestjs/common";
import { InjectRepository } from "@nestjs/typeorm";
import { Repository } from "typeorm";
import { Document } from "../entities/document.entity";
import { AuthenticatedUser } from "../../../common/guards/oidc-auth.guard";

@Injectable()
export class DocumentsService {
  constructor(
    @InjectRepository(Document)
    private documentsRepository: Repository<Document>
  ) {}

  async findAllByCompany(companyId: string): Promise<Document[]> {
    // Filtrar por empresa del usuario autenticado
    return this.documentsRepository.find({
      where: { company_id: companyId },
    });
  }

  async create(data: Partial<Document>): Promise<Document> {
    const document = this.documentsRepository.create(data);
    return this.documentsRepository.save(document);
  }

  async findOne(id: string, companyId: string): Promise<Document> {
    // Asegurar que el documento pertenece a la empresa
    const document = await this.documentsRepository.findOne({
      where: { id, company_id: companyId },
    });

    if (!document) {
      throw new NotFoundException("Document not found or access denied");
    }

    return document;
  }

  async update(
    id: string,
    data: Partial<Document>,
    user: AuthenticatedUser
  ): Promise<Document> {
    // Verificar permisos antes de actualizar
    const document = await this.findOne(id, user.company_id);

    Object.assign(document, data);
    return this.documentsRepository.save(document);
  }

  async remove(id: string, companyId: string): Promise<void> {
    const document = await this.findOne(id, companyId);
    await this.documentsRepository.remove(document);
  }
}
```

