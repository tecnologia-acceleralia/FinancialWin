OIDC_PUBLIC_URL=https://auth.test.acceleralia.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=https://your-api.com/api/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=https://your-frontend.com
