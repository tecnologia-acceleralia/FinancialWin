## 🔒 Protección de Endpoints

### NestJS - Usar Guard

```typescript
import { Controller, Get, UseGuards, Req } from "@nestjs/common";
import { OIDCAuthGuard } from "../common/guards/oidc-auth.guard";
import { Request } from "express";

@Controller("api/protected")
@UseGuards(OIDCAuthGuard) // Protege todos los endpoints del controlador
export class ProtectedController {
  @Get("data")
  getData(@Req() req: Request) {
    // req.user está disponible gracias al guard
    const companyId = req.user.company_id;

    // Filtrar datos por company_id (multi-tenant)
    return {
      message: "Protected data",
      companyId: companyId,
      user: req.user.email,
    };
  }

  @Get("other")
  @UseGuards(OIDCAuthGuard) // O proteger endpoints individuales
  getOther(@Req() req: Request) {
    return { data: "other", companyId: req.user.company_id };
  }
}
```

### Express - Usar Middleware

```typescript
import express from "express";
import { oidcAuthMiddleware } from "./middleware/oidc-auth.middleware";

const app = express();

// Aplicar middleware a rutas específicas
app.get(
  "/api/protected/data",
  oidcAuthMiddleware(
    process.env.OIDC_ISSUER_URL!,
    process.env.OIDC_CLIENT_ID!,
    process.env.OIDC_COOKIE_NAME!
  ),
  (req, res) => {
    res.json({
      message: "Protected data",
      companyId: req.user.company_id,
      user: req.user.email,
    });
  }
);
```

