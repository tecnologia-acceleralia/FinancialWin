## 🔧 Implementación para Express

Si estás usando Express en lugar de NestJS, crea los siguientes archivos:

### Middleware de Autenticación

Crea `src/middleware/oidc-auth.middleware.ts`:

```typescript
import { Request, Response, NextFunction } from "express";
import axios from "axios";

export interface AuthenticatedUser {
  sub: string;
  email: string;
  name: string;
  company_id: string;
  accessToken: string;
}

declare global {
  namespace Express {
    interface Request {
      user?: AuthenticatedUser;
    }
  }
}

export function oidcAuthMiddleware(
  oidcIssuerUrl: string,
  clientId: string,
  cookieName: string
) {
  return async (req: Request, res: Response, next: NextFunction) => {
    const authHeader = req.headers.authorization;
    const token = authHeader?.startsWith("Bearer ")
      ? authHeader.substring(7)
      : req.cookies?.[cookieName];

    if (!token) {
      return res.status(401).json({ error: "Authentication required" });
    }

    try {
      const validationResponse = await axios.post(
        `${oidcIssuerUrl}/api/token/validate`,
        { token },
        {
          params: { client_id: clientId },
          timeout: 5000,
        }
      );

      if (!validationResponse.data.valid) {
        return res.status(401).json({
          error: validationResponse.data.error || "Token validation failed",
        });
      }

      req.user = {
        sub: validationResponse.data.user.sub,
        email: validationResponse.data.user.email,
        name: validationResponse.data.user.name,
        company_id: validationResponse.data.user.company_id,
        accessToken: token,
      };

      next();
    } catch (error: any) {
      if (error.response?.status === 403) {
        return res.status(403).json({
          error: "Your company does not have access to this application",
        });
      }

      if (error.code === "ECONNREFUSED" || error.code === "ETIMEDOUT") {
        return res.status(503).json({
          error: "Authentication service unavailable",
        });
      }

      return res.status(401).json({ error: "Token validation failed" });
    }
  };
}
