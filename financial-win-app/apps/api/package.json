{
  "name": "financial-win-api",
  "version": "1.0.0",
  "description": "NestJS Backend",
  "author": "Acceleralia Team",
  "private": true,
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "migration:validate": "node scripts/validate-migrations.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:unit": "jest --testPathPattern=spec.ts",
    "test:integration": "jest --testPathPattern=integration.spec.ts",
    "test:all": "jest --coverage --testPathPattern=spec.ts|integration.spec.ts",
    "clean": "rm -rf dist",
    "migration:generate": "typeorm migration:generate -d data-source.cjs",
    "migration:run": "typeorm migration:run -d data-source.cjs",
    "migration:revert": "typeorm migration:revert -d data-source.cjs",
    "migration:show": "typeorm migration:show -d data-source.cjs",
    "migration:create": "typeorm migration:create",
    "migration:dev:reset": "node scripts/reset-dev-db.js",
    "migration:prod": "node scripts/run-migrations-prod.js run",
    "migration:prod:status": "node scripts/run-migrations-prod.js status",
    "migration:prod:check": "node scripts/run-migrations-prod.js check",
    "migration:prod:revert": "typeorm migration:revert -d data-source.cjs",
    "migration:prod:show": "typeorm migration:show -d data-source.cjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.928.0",
    "@aws-sdk/s3-request-presigner": "^3.928.0",
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/event-emitter": "^3.0.1",
    "axios": "^1.13.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.0.0",
    "multer": "^1.4.5-lts.2",
    "nest-commander": "^3.20.1",
    "openai": "6.9.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "source-map-support": "^0.5.21",
    "typeorm": "^0.3.27",
    "uuid": "^9.0.1",
    "zod": "^3.25.76",
    "@financial-win/shared-types": "workspace:*",
    "@financial-win/shared-config": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.8",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/jsdom": "^27.0.0",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.19.0",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unused-imports": "^4.3.0",
    "jest": "^29.7.0",
    "jsdom": "^22.1.0",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  }
}
