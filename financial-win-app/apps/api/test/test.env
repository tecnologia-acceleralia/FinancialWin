# =============================================================================
# Test Environment Variables
# =============================================================================
# Este archivo contiene las variables de entorno específicas para ejecutar tests.
# Estas variables son usadas por Jest cuando ejecuta los tests unitarios.
#
# IMPORTANTE:
# - Este archivo NO debe contener secrets reales
# - Usa valores de prueba/mock para todas las configuraciones
# - Las variables aquí definidas tienen prioridad sobre .env.dev y .env
# =============================================================================

# -----------------------------------------------------------------------------
# Entorno de Ejecución
# -----------------------------------------------------------------------------
NODE_ENV=test

# -----------------------------------------------------------------------------
# Base de Datos (SQLite en memoria para tests unitarios)
# -----------------------------------------------------------------------------
# Los tests unitarios usan SQLite en memoria (:memory:) configurado en test/setup.ts
# No se requieren variables de conexión para tests unitarios

# Para tests e2e, se usa PostgreSQL real con estas variables:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=test_user
# DB_PASSWORD=test_password
# DB_NAME=test_db
# DATABASE_URL=postgresql://test_user:test_password@localhost:5432/test_db

# -----------------------------------------------------------------------------
# Autenticación JWT
# -----------------------------------------------------------------------------
# Secret para generar tokens JWT en tests (NO usar en producción)
JWT_SECRET=test-secret-key-for-jwt-tokens-in-tests-only
JWT_EXPIRES_IN=24h

# -----------------------------------------------------------------------------
# OIDC Configuration (Mock/Test values)
# -----------------------------------------------------------------------------
OIDC_PROVIDER_URL=http://localhost:5009
OIDC_CLIENT_ID=test-client-id
OIDC_CLIENT_SECRET=test-client-secret
OIDC_REDIRECT_URI=http://localhost:6000/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3008

# -----------------------------------------------------------------------------
# Storage Configuration (Mock/Test values)
# -----------------------------------------------------------------------------
# Digital Ocean Spaces - Valores de prueba (NO usar en producción)
BUCKET_URL_STORAGE=https://test-bucket.nyc3.digitaloceanspaces.com
DO_SPACES_ENDPOINT=nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_ACCESS_KEY_ID=test-access-key-id
DO_SPACES_SECRET_ACCESS_KEY=test-secret-access-key
DO_SPACES_BUCKET_NAME=test-bucket

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
PORT=6000
CORS_ORIGIN=http://localhost:3008

# -----------------------------------------------------------------------------
# Rate Limiting (Relajado para tests)
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
UPLOAD_DIR=./test-uploads
MAX_FILE_SIZE_MB=10
MAX_PROJECT_FILES_MB=30

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Desactivar logging en tests para mantener output limpio
LOG_LEVEL=error

# -----------------------------------------------------------------------------
# AI/OpenAI Configuration (Mock/Test values)
# -----------------------------------------------------------------------------
# Si los tests requieren OpenAI, usar valores de prueba
# OPENAI_API_KEY=test-api-key
# AI_MODEL=gpt-4o-mini
# AI_TEMPERATURE_EXPERT=0.3
# AI_TEMPERATURE_EVALUATOR=0.0
# AI_MAX_TOKENS=1000

# =============================================================================
# Notas Importantes
# =============================================================================
# 1. Los tests unitarios usan SQLite en memoria, no requieren base de datos real
# 2. Los tests e2e requieren PostgreSQL real y deben configurarse por separado
# 3. Todos los valores aquí son para testing y NO deben usarse en producción
# 4. Si necesitas agregar nuevas variables, agrégalas aquí y en .env.example
# =============================================================================
