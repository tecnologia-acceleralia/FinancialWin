NODE_ENV=development
PORT=6006

# -----------------------------------------------------------------------------
# Configuración de Base de Datos
# -----------------------------------------------------------------------------
# En Docker: usar 'postgres' (nombre del servicio en docker-compose)
# En ejecución local: usar 'localhost'
DB_HOST=postgres
DB_PORT=5555
DB_USERNAME=financial-win
DB_PASSWORD=financial-win
DB_NAME=financial-win_dev

# Connection string completo de PostgreSQL.
# Formato: postgresql://usuario:password@host:puerto/nombre_db
# 
# Para Docker: usar 'postgres' como hostname
# Para ejecución local: usar 'localhost'
DATABASE_URL=postgresql://financial-win:financial-win@financial-win:5555/financial-win_dev

# Si true, habilita SSL para la conexión a PostgreSQL.
# En desarrollo: false
# En producción: true (requerido para conexiones remotas)
DB_SSL=false

OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Controla la protección contra abuso de la API.

# Número máximo de requests permitidos dentro de la ventana de tiempo.
RATE_LIMIT_REQUESTS=3

# Ventana de tiempo (en segundos) para contar los requests.
# Ejemplo: 3 requests en 10 segundos = bloqueo temporal.
RATE_LIMIT_WINDOW_SECONDS=10

# Configuración CORS
# -----------------------------------------------------------------------------
# Controla qué orígenes pueden hacer requests a la API.

# Origen permitido para requests CORS (URL del frontend).
# En desarrollo: http://localhost:3010
# En producción: https://app.tudominio.com
# 
# CORS_ORIGIN=http://localhost:3003,https://app.tudominio.com
CORS_ORIGIN=http://localhost:3003


# -----------------------------------------------------------------------------
# JWT Secret (CRÍTICO - Compartido)
# -----------------------------------------------------------------------------
# Clave secreta para firmar y verificar tokens JWT de sesión.
# es una clave secreta compartida para firmar y verificar tokens JWT internos entre 
# oidc-server y los módulos satélites (como write-mvp). 
# No es para conectarse al servidor OIDC, sino para que ambos servicios puedan firmar y verificar tokens.
#
# IMPORTANTE: Este valor DEBE ser idéntico en:
#   - My-App/apps/api/.env.dev
#   - oidc-server/provider/.env
#   - Cualquier otro módulo que genere tokens de sesión
#
# Si los valores no coinciden, la validación de tokens fallará.
#  
JWT_SECRET=este-valor-te-lo-van-a-pasar-para-que-te-funcione-todo-piola

# Si 0, desactiva la verificación de certificados TLS (SOLO desarrollo).
# En producción: NUNCA usar 0, siempre verificar certificados.
# 

# -----------------------------------------------------------------------------
# Configuración OIDC (OpenID Connect)
# -----------------------------------------------------------------------------
# Configuración para autenticación con el OIDC Provider.

# URL del issuer OIDC (desde dentro de Docker).
# En Docker: usar 'host.docker.internal' para acceder al host
# En local: usar 'localhost'
OIDC_ISSUER_URL=http://host.docker.internal:5009

# URL pública del OIDC Provider (accesible desde el navegador).
# Esta URL se usa para redirecciones del navegador en flujos OAuth/OIDC.
OIDC_PUBLIC_URL=http://localhost:5009

# URL donde el provider OIDC redirige después de la autenticación.
# Formato: {API_URL}/auth/callback
OIDC_REDIRECT_URI=http://localhost:6006/api/auth/callback

# URL donde redirigir después del logout.
# Generalmente la URL del frontend.
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3003

# Client ID único que identifica esta API en el provider.
# Debe coincidir con el client_id registrado en el admin panel del provider.
OIDC_CLIENT_ID=financial-win-client

# Client Secret para autenticar esta API ante el provider.
# IMPORTANTE: Este valor DEBE coincidir con:
#   - El valor configurado en oidc-server/provider/.env como CLIENT_SECRET_<CLIENT_ID>
#   - El hash almacenado en la BD del provider
#
# Si los valores no coinciden, la autenticación OIDC fallará.
OIDC_CLIENT_SECRET=financial-win-secret-super-seguro-al-azar-32chars

# Scopes OIDC solicitados durante la autenticación.
# Scopes disponibles: openid, email, profile, address, phone, offline_access
# Separar múltiples scopes con espacios.
OIDC_SCOPES=openid email profile

# -----------------------------------------------------------------------------
# Configuración de Cookies OIDC
# -----------------------------------------------------------------------------
# Controla el comportamiento de las cookies de sesión OIDC.

# Nombre de la cookie que almacena el token de sesión.
OIDC_COOKIE_NAME=financial-win_session

# Si true, las cookies solo se envían sobre HTTPS.
# En desarrollo: false (permite HTTP)
# En producción: true (requiere HTTPS)
OIDC_COOKIE_SECURE=false

# Política SameSite para cookies OIDC.
# Valores: 'strict', 'lax', 'none'
# 'lax' es recomendado para permitir redirects OAuth.
OIDC_COOKIE_SAME_SITE=lax

# Tiempo de vida de la cookie (en milisegundos).
# 1800000 = 30 minutos
OIDC_COOKIE_MAX_AGE=604800000

# Ventana de tiempo antes de la expiración para refrescar el token (en milisegundos).
# 300000 = 5 minutos (refresca cuando quedan 5 minutos antes de expirar)
OIDC_TOKEN_REFRESH_WINDOW=1800000

# Dominio para las cookies (vacío = solo mismo origen).
# En desarrollo: vacío o 'localhost'
# En producción: '.tudominio.com' (con punto inicial para subdominios)
OIDC_COOKIE_DOMAIN=

# Ruta donde la cookie es válida.
# '/' = toda la aplicación
OIDC_COOKIE_PATH=/

# -----------------------------------------------------------------------------
# Configuración de Debug
# -----------------------------------------------------------------------------
# Controla endpoints y funcionalidades de debug.

# Si true, habilita endpoints de debug (información sensible).
# En desarrollo: puede ser true para debugging
# En producción: SIEMPRE false (riesgo de seguridad)
ENABLE_DEBUG_ENDPOINT=false
